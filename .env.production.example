# Production Environment Variables Template
# Copy this file to .env on the production server and fill in the values

# Database Configuration
DB_HOST=172.16.17.68
DB_PORT=3306
DB_NAME=tendertrack_db
DB_USER=your_db_user
DB_PASSWORD=your_secure_password

# Server Configuration
PORT=5000
NODE_ENV=production

# JWT Configuration
JWT_SECRET=your_very_secure_jwt_secret_key_here
JWT_EXPIRES_IN=24h

# CORS Configuration
CORS_ORIGIN=https://tendertracker.mobilisepro.com

# Application URL (used for share links, OAuth callbacks, emails)
APP_URL=https://tendertracker.mobilisepro.com

# AI Service Configuration (Optional - configure in admin panel)
OPENAI_API_KEY=
GEMINI_API_KEY=
HUGGINGFACE_API_KEY=

# Email Configuration (SendGrid)
SENDGRID_API_KEY=
FROM_EMAIL=noreply@tendertracker.mobilisepro.com

# SMS Configuration (Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# File Upload Configuration
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Session Configuration
SESSION_SECRET=your_session_secret_here

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
