{
  "name": "leadtrack-backend",
  "version": "1.0.0",
  "description": "LeadTrack Pro Backend API",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "build": "tsc",
    "start": "node dist/app.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:integration": "jest --config jest.integration.config.js",
    "test:security": "jest --config jest.security.config.js",
    "migrate": "ts-node scripts/migrate.ts",
    "migrate:up": "ts-node scripts/migrate.ts up",
    "migrate:down": "ts-node scripts/migrate.ts down",
    "setup-db": "ts-node scripts/setup-database.ts",
    "backup": "ts-node scripts/backup-database.ts",
    "generate-hash": "ts-node scripts/generate-password-hash.ts",
    "migrate:soft-delete": "ts-node scripts/run-soft-delete-migration.ts",
    "migrate:emd-fees": "ts-node scripts/run-emd-fees-migration.ts",
    "migrate:reminders": "ts-node scripts/run-reminders-migration.ts",
    "migrate:document-fields": "ts-node scripts/run-document-name-description-migration.ts",
    "migrate:otp-purpose": "ts-node scripts/run-otp-purpose-migration.ts",
    "migrate:ai-configs": "ts-node scripts/run-ai-configs-migration.ts",
    "migrate:ai-summary": "ts-node scripts/run-ai-summary-migration.ts",
    "migrate:crm": "ts-node scripts/run-crm-migrations.ts safe",
    "migrate:crm:rename": "ts-node scripts/run-crm-migrations.ts rename",
    "migrate:tender-scout": "ts-node scripts/run-tender-scout-migration.ts",
    "migrate:document-categories": "ts-node scripts/run-document-categories-seed.ts",
    "test:notifications": "ts-node scripts/send-test-notifications.ts",
    "send-reminders": "ts-node src/scripts/send-reminders.ts"
  },
  "keywords": [
    "tender",
    "tracking",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@sendgrid/mail": "^8.1.6",
    "@types/node-fetch": "^2.6.13",
    "axios": "^1.6.2",
    "bcrypt": "^5.1.1",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.6.5",
    "node-cron": "^3.0.3",
    "node-fetch": "^2.7.0",
    "nodemailer": "^6.9.7",
    "pdf-parse": "^2.4.5",
    "robots-parser": "^3.0.1",
    "rss-parser": "^3.13.0",
    "string-similarity": "^4.0.4",
    "twilio": "^4.19.0",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.5",
    "@types/nodemailer": "^6.4.14",
    "@types/pdf-parse": "^1.1.5",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3",
    "ts-jest": "^29.1.1",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}